{
  "name": "skytest-agent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "cli-runner"
  ],
  "overrides": {
    "@hono/node-server": "1.19.10",
    "@modelcontextprotocol/sdk": "$@modelcontextprotocol/sdk",
    "dompurify": "3.3.2",
    "hono": "4.12.4",
    "ajv@8.17.1": "8.18.0",
    "ajv@^6.12.4": "6.14.0",
    "axios@1.9.0": "1.13.5",
    "form-data@4.0.2": "4.0.4",
    "glob@10.4.5": "10.5.0",
    "minimatch@5.1.6": "10.2.3",
    "minimatch@^3.1.1": "3.1.4",
    "minimatch@^3.1.2": "3.1.4",
    "minimatch@2 || 3": "3.1.4",
    "minimatch@^9.0.4": "9.0.7",
    "minimatch@^9.0.5": "9.0.7",
    "js-yaml": ">=4.1.1",
    "lodash": ">=4.17.23",
    "qs": ">=6.14.2"
  },
  "scripts": {
    "dev": "next dev",
    "dev:services:up": "docker compose -f docker-compose.local.yml up -d",
    "dev:services:down": "docker compose -f docker-compose.local.yml down",
    "dev:services:logs": "docker compose -f docker-compose.local.yml logs -f postgres minio createbuckets",
    "build": "next build",
    "start": "next start",
    "lint": "npm run db:generate && eslint && npx tsc --noEmit --incremental false",
    "audit": "npm audit --audit-level=moderate --package-lock-only",
    "verify": "npm run lint && npm run audit",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "playwright:install": "playwright install chromium",
    "test": "vitest --run",
    "runner:maintenance": "tsx src/workers/runner-maintenance.ts",
    "runner:browser": "tsx src/workers/browser-runner.ts",
    "skytest": "npm run --workspace @skytest/cli-runner skytest --",
    "skytest:help": "npm run --workspace @skytest/cli-runner skytest:help"
  },
  "dependencies": {
    "@authgear/web": "5.0.1",
    "@aws-sdk/client-s3": "3.1003.0",
    "@aws-sdk/s3-request-presigner": "3.1003.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@langfuse/openai": "4.6.1",
    "@midscene/android": "1.5.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@monaco-editor/react": "4.7.0",
    "@prisma/adapter-pg": "7.4.1",
    "@prisma/client": "7.4.1",
    "@tailwindcss/postcss": "4.1.18",
    "@types/archiver": "7.0.0",
    "archiver": "7.0.1",
    "exceljs": "4.4.0",
    "jose": "6.1.3",
    "langsmith": "0.5.8",
    "next": "16.1.5",
    "pg": "8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@midscene/web": "1.5.1",
    "@playwright/test": "1.57.0",
    "@types/node": "25.0.3",
    "@types/pg": "8.18.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.23",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.5",
    "playwright": "1.57.0",
    "postcss": "8.5.6",
    "prisma": "7.4.1",
    "tailwindcss": "4.1.18",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
