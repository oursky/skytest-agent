generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TeamRole {
  OWNER
  MEMBER
}

model RateLimitWindow {
  bucketKey     String
  windowStartMs BigInt
  count         Int
  updatedAt     DateTime @default(now())

  @@id([bucketKey, windowStartMs])
  @@index([updatedAt])
}

model User {
  id                String          @id @default(cuid())
  authId            String          @unique
  email             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdProjects   Project[]       @relation("ProjectCreator")
  actorUsageRecords UsageRecord[]   @relation("UsageRecordActor")
  apiKeys           ApiKey[]
  teamMemberships   TeamMembership[]
  createdRunnerTokens RunnerToken[] @relation("RunnerTokenCreator")
}

model UsageRecord {
  id          String   @id @default(cuid())
  actorUserId String
  actorUser   User     @relation("UsageRecordActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String   // "TEST_RUN"
  description String?  // e.g., "Project Name - Test Case Name"
  aiActions   Int      // Exact number of AI actions executed
  testRunId   String?  // Reference to test run for linking
  testRun     TestRun? @relation(fields: [testRunId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([projectId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([projectId, actorUserId, createdAt(sort: Desc)])
}

model Team {
  id                     String                   @id @default(cuid())
  name                   String
  openRouterKeyEncrypted String?
  openRouterKeyUpdatedAt DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  memberships            TeamMembership[]
  projects               Project[]
  runners                Runner[]
  runnerTokens           RunnerToken[]

  @@index([updatedAt(sort: Desc)])
}

model TeamMembership {
  id        String    @id @default(cuid())
  teamId    String
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String?
  role      TeamRole
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([teamId, userId])
  @@index([userId, teamId])
  @@index([teamId, role])
  @@index([teamId, email])
  @@index([email])
}

model Project {
  id              String              @id @default(cuid())
  name            String
  teamId  String
  team    Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdByUser   User                @relation("ProjectCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  testCases       TestCase[]
  configs         ProjectConfig[]
  usageRecords    UsageRecord[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([teamId, updatedAt(sort: Desc)])
  @@index([createdByUserId, updatedAt(sort: Desc)])
}

model TestCase {
  id        String           @id @default(cuid())
  displayId String?          // User-editable display ID (optional)
  status    String           @default("DRAFT") // DRAFT | PASS | FAIL | CANCELLED | RUNNING | QUEUED
  name      String
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  prompt    String?
  steps     String?
  browserConfig String?
  source    String?
  testRuns  TestRun[]
  files     TestCaseFile[]
  configs   TestCaseConfig[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([projectId, updatedAt(sort: Desc)])
}

model TestCaseFile {
  id          String   @id @default(cuid())
  testCaseId  String
  testCase    TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  filename    String
  storedName  String
  mimeType    String
  size        Int
  createdAt   DateTime @default(now())

  @@unique([testCaseId, filename])
  @@index([testCaseId])
}

model TestRun {
  id                      String   @id @default(cuid())
  testCaseId              String
  testCase                TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  requiredCapability      String?
  requiredRunnerKind      String?
  requestedDeviceId       String?
  assignedRunnerId        String?
  assignedRunner          Runner?  @relation("AssignedRunnerRuns", fields: [assignedRunnerId], references: [id], onDelete: SetNull)
  leaseExpiresAt          DateTime?
  lastEventAt             DateTime?
  nextEventSequence       Int      @default(1)
  status                  String
  result                  String?
  logs                    String?
  error                   String?
  configurationSnapshot   String?
  startedAt               DateTime?
  completedAt             DateTime?
  deletedAt               DateTime?
  createdAt               DateTime @default(now())
  usageRecords            UsageRecord[]
  files                   TestRunFile[]
  events                  TestRunEvent[]

  @@index([testCaseId, createdAt(sort: Desc)])
  @@index([status])
  @@index([status, requiredCapability, createdAt(sort: Asc)])
  @@index([assignedRunnerId, leaseExpiresAt])
  @@index([requestedDeviceId])
  @@index([deletedAt, completedAt(sort: Asc)])
}

model TestRunFile {
  id         String   @id @default(cuid())
  runId      String
  testRun    TestRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  filename   String
  storedName String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())

  @@index([runId])
}

model ProjectConfig {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  type      String   // URL | APP_ID | VARIABLE | RANDOM_STRING | FILE
  value     String
  masked    Boolean  @default(false)
  group     String?
  filename  String?
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  prefix     String
  hash       String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model TestCaseConfig {
  id         String   @id @default(cuid())
  testCaseId String
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  name       String
  type       String   // URL | APP_ID | VARIABLE | RANDOM_STRING | FILE
  value      String
  masked     Boolean  @default(false)
  group      String?
  filename   String?
  mimeType   String?
  size       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([testCaseId, name])
  @@index([testCaseId])
}

model Runner {
  id              String       @id @default(cuid())
  teamId          String
  team            Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  label           String
  kind            String
  capabilities    String[]     @default([])
  protocolVersion String
  runnerVersion   String
  status          String       @default("ONLINE")
  lastSeenAt      DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tokens          RunnerToken[]
  devices         RunnerDevice[]
  assignedRuns    TestRun[]    @relation("AssignedRunnerRuns")

  @@index([teamId, kind])
  @@index([teamId, status, lastSeenAt])
}

model RunnerToken {
  id              String    @id @default(cuid())
  teamId          String
  team            Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  runnerId        String?
  runner          Runner?   @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  createdByUserId String?
  createdByUser   User?     @relation("RunnerTokenCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  kind            String
  prefix          String
  hash            String    @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  consumedAt      DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([teamId, kind, expiresAt])
  @@index([runnerId, kind, expiresAt])
}

model RunnerDevice {
  id         String   @id @default(cuid())
  runnerId   String
  runner     Runner   @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  deviceId   String
  platform   String
  name       String
  state      String
  metadata   Json?
  lastSeenAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([runnerId, deviceId])
  @@index([runnerId, state, lastSeenAt])
}

model TestRunEvent {
  id          String   @id @default(cuid())
  runId       String
  testRun     TestRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  sequence    Int
  kind        String
  message     String?
  payload     Json?
  artifactKey String?
  createdAt   DateTime @default(now())

  @@unique([runId, sequence])
  @@index([runId, createdAt(sort: Asc)])
  @@index([createdAt(sort: Desc)])
}
