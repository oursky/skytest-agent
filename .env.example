# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skytest_agent?schema=public"

# Object Storage (use local MinIO for development, S3-compatible storage in hosted environments)
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=skytest-agent
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_TTL_SECONDS=900

# Authgear Authentication (https://portal.authgear.com/)
NEXT_PUBLIC_AUTHGEAR_CLIENT_ID=a1b2c3d4e5f6g7h8
NEXT_PUBLIC_AUTHGEAR_ENDPOINT=https://your-project.authgear.cloud
NEXT_PUBLIC_AUTHGEAR_REDIRECT_URI=http://localhost:3000/auth-redirect

# Encryption secret for API key storage (generate a random 32+ character string)
ENCRYPTION_SECRET=your-random-secret-key-here

# AI Model Configuration (https://openrouter.ai/)
MIDSCENE_MODEL_BASE_URL=https://openrouter.ai/api/v1
MIDSCENE_MODEL_NAME=bytedance-seed/seed-1.6-flash
MIDSCENE_MODEL_FAMILY=doubao-vision

MIDSCENE_PLANNING_MODEL_BASE_URL=https://openrouter.ai/api/v1
MIDSCENE_PLANNING_MODEL_NAME=qwen/qwen3.5-35b-a3b
MIDSCENE_PLANNING_MODEL_FAMILY=qwen3.5

MIDSCENE_INSIGHT_MODEL_BASE_URL=https://openrouter.ai/api/v1
MIDSCENE_INSIGHT_MODEL_NAME=qwen/qwen3.5-35b-a3b
MIDSCENE_INSIGHT_MODEL_FAMILY=qwen3.5

# AI Model Behavior (stricter = lower temperature)
MIDSCENE_MODEL_TEMPERATURE=0.2
